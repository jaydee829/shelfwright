# Keep the build context small and avoid copying host-only / generated data.
.git
.github
.venv
venv
__pycache__
*.py[cod]
.pytest_cache
.ruff_cache
.coverage
htmlcov
.dvc/cache
.dvc/tmp
data/raw/*.csv
mlruns
.env
*.log
data/
.chat_logs/
docs/
test/
*.egg-info
__pycache__/
scripts/
diagrams/
scratch/
.devcontainer/
.vscode/
.agent/
.gemini/
.claude/
# Node: let `npm ci` build a clean, linux-correct node_modules inside the image
# (the new multi-stage Dockerfile COPYs frontend/ — never ship the host's win32 tree).
**/node_modules
frontend/dist
